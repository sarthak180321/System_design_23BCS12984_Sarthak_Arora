        <mxCell id="pa7MBm2g2tbfWt3tLwff-46" edge="1" parent="1" source="pa7MBm2g2tbfWt3tLwff-41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="pa7MBm2g2tbfWt3tLwff-43" value="&lt;font color=&quot;#FFFFFF&quot;&gt;3. Cassandra &#39;PENDING&#39;&lt;/font&gt;">
