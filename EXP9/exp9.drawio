        <mxCell id="pa7MBm2g2tbfWt3tLwff-47" edge="1" parent="1" source="pa7MBm2g2tbfWt3tLwff-41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="pa7MBm2g2tbfWt3tLwff-44" value="&lt;font color=&quot;#FFFFFF&quot;&gt;4. Payment Handshake&lt;/font&gt;">
          <mxGeometry relative="1" x="-0.1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
