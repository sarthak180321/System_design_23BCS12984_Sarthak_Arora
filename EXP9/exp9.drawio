        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-43" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#90EE90;strokeColor=#000000;strokeWidth=3;" value="&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;CASSANDRA&lt;/b&gt;&lt;br&gt;Row Status: PENDING&lt;br&gt;TTL: 300s&lt;br&gt;Write: Local_Quorum&lt;/font&gt;" vertex="1">
