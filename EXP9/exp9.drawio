        <mxCell id="pa7MBm2g2tbfWt3tLwff-42" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DDA0DD;strokeColor=#000000;strokeWidth=3;" value="&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;REDIS&lt;/b&gt;&lt;br&gt;Distributed Lock&lt;br&gt;SETNX seat_id user_id&lt;br&gt;TTL: 20s (Auto-Release)&lt;/font&gt;" vertex="1">
