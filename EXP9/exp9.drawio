        </mxCell>
        <mxCell id="cassandra_db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#90EE90;strokeColor=#000000;strokeWidth=3;" value="&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;CASSANDRA&lt;/b&gt;&lt;br&gt;Row Status: PENDING&lt;br&gt;TTL: 300s&lt;br&gt;Write: Local_Quorum&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="450" y="270" as="geometry" />
        </mxCell>
        <mxCell id="payment_gw" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFD700;strokeColor=#000000;strokeWidth=3;" value="&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;Payment Gateway&lt;/b&gt;&lt;br&gt;Stripe / Razorpay API&lt;br&gt;Event: Webhook Sync&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="450" y="450" as="geometry" />
        </mxCell>
        <mxCell id="flow1" edge="1" parent="1" source="user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="booking_logic" value="&lt;font color=&quot;#FFFFFF&quot;&gt;1. Click &#39;Book Seat&#39;&lt;/font&gt;">
          <mxGeometry relative="1" y="15" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow2" edge="1" parent="1" source="booking_logic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="redis_lock" value="&lt;font color=&quot;#FFFFFF&quot;&gt;2. SETNX Lock&lt;/font&gt;">
          <mxGeometry relative="1" x="-0.1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow3" edge="1" parent="1" source="booking_logic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="cassandra_db" value="&lt;font color=&quot;#FFFFFF&quot;&gt;3. Cassandra &#39;PENDING&#39;&lt;/font&gt;">
          <mxGeometry relative="1" x="-0.1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow4" edge="1" parent="1" source="booking_logic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="payment_gw" value="&lt;font color=&quot;#FFFFFF&quot;&gt;4. Payment Handshake&lt;/font&gt;">
          <mxGeometry relative="1" x="-0.1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow5" edge="1" parent="1" source="payment_gw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;dashed=1;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="booking_logic" value="&lt;font color=&quot;#FFFFFF&quot;&gt;5. Payment Success&lt;/font&gt;">
          <mxGeometry relative="1" x="0.2" y="-20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow6" edge="1" parent="1" source="booking_logic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1.006;exitY=0.693;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.011;entryY=0.792;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="cassandra_db" value="&lt;font color=&quot;#FFFFFF&quot;&gt;6. Final Commit (Update status)&lt;/font&gt;">
          <mxGeometry relative="1" x="0.4" y="30" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="flow7" edge="1" parent="1" source="booking_logic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1.006;exitY=0.143;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.105;entryY=0.827;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="redis_lock" value="&lt;font color=&quot;#FFFFFF&quot;&gt;7. Release Redis Lock&lt;/font&gt;">
          <mxGeometry relative="1" x="0.2" y="-30" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="TeIn Redis, you can use &lt;code data-path-to-node=&quot;4&quot; data-index-in-node=&quot;67&quot;&gt;SETNX&lt;/code&gt; (Set if Not Exists). This combines the &quot;check&quot; and the &quot;lock&quot; into one single step. If the command returns &lt;code data-path-to-node=&quot;4&quot; data-index-in-node=&quot;180&quot;&gt;1&lt;/code&gt;, the user got the lock; if it returns &lt;code data-path-to-node=&quot;4&quot; data-index-in-node=&quot;220&quot;&gt;0&lt;/code&gt;, someone else beat them to it.t" vertex="1">
          <mxGeometry height="90" width="520" x="120" y="670" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Atomic lock&lt;br&gt;check and set at once&lt;/h1&gt;" vertex="1">
          <mxGeometry height="75" width="260" x="130" y="595" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-4" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2 Phase commit SYstem&lt;/h1&gt;" vertex="1">
          <mxGeometry height="60" width="320" x="730" y="110" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-5" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;GHOST seating problem&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="40" width="310" x="130" y="760" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="if the database write fails &lt;i data-path-to-node=&quot;10&quot; data-index-in-node=&quot;41&quot;&gt;after&lt;/i&gt; the payment is successful, but the Redis lock expires? You’d have a &quot;Ghost Seat&quot; where someone paid, but the seat looks available again." vertex="1">
          <mxGeometry height="80" width="430" x="120" y="790" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;FLOW of GHOSt seating&lt;/h1&gt;" vertex="1">
          <mxGeometry height="50" width="310" x="130" y="870" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="1.)&lt;b data-path-to-node=&quot;4,0,0&quot; data-index-in-node=&quot;0&quot;&gt;User A&lt;/b&gt; locks a seat in &lt;b data-path-to-node=&quot;4,0,0&quot; data-index-in-node=&quot;23&quot;&gt;Redis&lt;/b&gt; (20-second timeout) and proceeds to payment.&lt;br&gt;2.)The payment takes &lt;b data-path-to-node=&quot;4,1,0&quot; data-index-in-node=&quot;18&quot;&gt;25 seconds&lt;/b&gt; because the bank&#39;s SMS/OTP is slow.&lt;br&gt;3.)&lt;b data-path-to-node=&quot;4,2,0&quot; data-index-in-node=&quot;0&quot;&gt;Redis&lt;/b&gt; doesn&#39;t know the user is still paying, so it hits the 20s limit and &lt;b data-path-to-node=&quot;4,2,0&quot; data-index-in-node=&quot;74&quot;&gt;deletes the lock&lt;br&gt;4.)&lt;/b&gt;&lt;b data-path-to-node=&quot;4,3,0&quot; data-index-in-node=&quot;0&quot;&gt;User B&lt;/b&gt; searches for tickets, sees the seat is &quot;available&quot; (because the lock is gone), and clicks &quot;Book.&lt;br&gt;5.)&lt;b data-path-to-node=&quot;4,4,0&quot; data-index-in-node=&quot;0&quot;&gt;User A&lt;/b&gt; finally finishes the payment. The gateway sends a &quot;Success&quot; signal." vertex="1">
          <mxGeometry height="180" width="420" x="120" y="920" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-9" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;SOLUTIONs to ghost seating problem&lt;/h1&gt;" vertex="1">
          <mxGeometry height="50" width="440" x="90" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-12" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;UID: 23BCS12984&lt;/h1&gt;" vertex="1">
          <mxGeometry height="40" width="280" x="710" y="30" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;p data-path-to-node=&quot;13&quot;&gt;Once the Redis lock is secured, we need a record that says &quot;this seat is in progress.&quot;&lt;/p&gt;&lt;ul data-path-to-node=&quot;14&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,0,0&quot;&gt;&lt;b data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;0&quot;&gt;Action:&lt;/b&gt; We write a row to &lt;b data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;26&quot;&gt;Cassandra&lt;/b&gt; with the status &lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;52&quot;&gt;PENDING&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;&amp;nbsp;We also give this row a TTL (e.g., 5 minutes) so it self-deletes if the payment never happens.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;If the payment is successful, the Gateway sends a &lt;b data-path-to-node=&quot;17,1,0&quot; data-index-in-node=&quot;50&quot;&gt;Webhook&lt;/b&gt; back to our Booking Engine.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;We change the status from &lt;code data-path-to-node=&quot;20,0,0&quot; data-index-in-node=&quot;44&quot;&gt;PENDING&lt;/code&gt; to &lt;code data-path-to-node=&quot;20,0,0&quot; data-index-in-node=&quot;55&quot;&gt;BOOKED&lt;/code&gt; and &lt;b data-path-to-node=&quot;20,0,0&quot; data-index-in-node=&quot;66&quot;&gt;remove the TTL&lt;/b&gt;. The seat is now permanently taken.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;We manually delete the Redis lock because we no longer need the 20-second &quot;temporary&quot; guard.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;a heartbeat system keeps tarcking the user progress in payment and keep refreshing the lock in redis&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="260" width="450" x="80" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;p data-path-to-node=&quot;13&quot;&gt;Before the user even sees the payment screen, we write a row in &lt;b data-path-to-node=&quot;13&quot; data-index-in-node=&quot;64&quot;&gt;Cassandra&lt;/b&gt; with &lt;code data-path-to-node=&quot;13&quot; data-index-in-node=&quot;79&quot;&gt;status: PENDING&lt;/code&gt;.&lt;/p&gt;&lt;ul data-path-to-node=&quot;14&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,0,0&quot;&gt;When the payment succeeds, the system first checks if that &lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;59&quot;&gt;PENDING&lt;/code&gt; record still exists and belongs to that specific &lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;116&quot;&gt;user_id&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;If &lt;b data-path-to-node=&quot;14,1,0&quot; data-index-in-node=&quot;3&quot;&gt;User B&lt;/b&gt; tried to take it, the system would see a conflict in the Database layer and block the final &quot;Booked&quot; confirmation for the second person.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="170" width="360" x="100" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="pa7MBm2g2tbfWt3tLwff-17" edge="1" parent="1" source="pa7MBm2g2tbfWt3tLwff-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="1740" as="targetPoint" />
          </mxGeometry>
        </mxCell>
