        <mxCell id="pa7MBm2g2tbfWt3tLwff-45" edge="1" parent="1" source="pa7MBm2g2tbfWt3tLwff-41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FFFFFF;strokeWidth=2;fontStyle=1" target="pa7MBm2g2tbfWt3tLwff-42" value="&lt;font color=&quot;#FFFFFF&quot;&gt;2. SETNX Lock&lt;/font&gt;">
