        </mxCell>
        <mxCell id="e_upload" edge="1" parent="1" source="node_puller" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeWidth=2;strokeColor=#4D9900;fontColor=#4D9900;" target="node_s3" value="HLS Watcher -&gt; S3 Upload">
          <mxGeometry relative="1" as="geometry">
