    {
      "id": "U-nz-X50iRtRYmJeuTUBT",
      "type": "text",
      "x": 11790.659726141777,
      "y": 25046.47686463179,
      "width": 646.7997436523438,
      "height": 665,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7V",
      "roundness": null,
      "seed": 1137128669,
      "version": 9,
      "versionNonce": 1131899411,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772519208081,
      "link": null,
      "locked": false,
      "text": "wss.on(\"connection\", (ws) => {\n\n   const streamKey = generateUniqueKey();\n\n   const ffmpeg = spawn(\"ffmpeg\", [\n      \"-i\", \"pipe:0\",\n      \"-c:v\", \"libx264\",\n      \"-f\", \"flv\",\n      `rtmp://localhost/live/${streamKey}`\n   ]);\n\n   ws.on(\"message\", (chunk) => {\n      ffmpeg.stdin.write(chunk);\n   });\n\n   ws.on(\"close\", () => {\n      ffmpeg.kill();\n   });\n});",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "wss.on(\"connection\", (ws) => {\n\n   const streamKey = generateUniqueKey();\n\n   const ffmpeg = spawn(\"ffmpeg\", [\n      \"-i\", \"pipe:0\",\n      \"-c:v\", \"libx264\",\n      \"-f\", \"flv\",\n      `rtmp://localhost/live/${streamKey}`\n   ]);\n\n   ws.on(\"message\", (chunk) => {\n      ffmpeg.stdin.write(chunk);\n   });\n\n   ws.on(\"close\", () => {\n      ffmpeg.kill();\n   });\n});",
      "autoResize": true,
      "lineHeight": 1.25
    },
